{
  "name": "@danielgindi/selectbox",
  "version": "2.0.53",
  "description": "A collection of dom utilities. So you can work natively with the dom without dom frameworks.",
  "main": "dist/lib.cjs.min.js",
  "module": "lib/index.js",
  "broswer": "dist/lib.umd.min.js",
  "author": {
    "name": "Daniel Cohen Gindi",
    "email": "danielgindi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/danielgindi/selectbox.git"
  },
  "directories": {
    "dist": "dist",
    "lib": "lib"
  },
  "scripts": {
    "benchmark": "node ./benchmarks/selectbox-value-lookup.mjs",
    "build": "npm run lint && node ./scripts/build.js",
    "lint": "eslint -f codeframe ./",
    "lint-fix": "eslint -f codeframe --fix ./",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "example": "vite"
  },
  "bugs": {
    "url": "https://github.com/danielgindi/selectbox/issues"
  },
  "homepage": "https://github.com/danielgindi/selectbox#readme",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "core-js": "^3.49.0",
    "eslint": "^10.7.0",
    "eslint-formatter-codeframe": "^7.32.2",
    "eslint-plugin-vue": "^10.9.2",
    "fs-extra": "^11.3.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "pinst": "^3.0.0",
    "rollup": "^4.62.2",
    "sass": "^1.101.0",
    "vite": "^8.1.5",
    "vue": "^3.5.40",
    "vue-eslint-parser": "^10.4.1"
  },
  "dependencies": {
    "@danielgindi/dom-utils": "^1.0.11",
    "@danielgindi/virtual-list-helper": "^1.0.18",
    "fast-deep-equal": "^3.1.3",
    "keycode-js": "^3.1.0",
    "mitt": "^3.0.1"
  },
  "peerDependencies": {
    "vue": "^2.* || ^3.*"
  }
}
